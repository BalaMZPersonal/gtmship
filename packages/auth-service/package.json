{
  "name": "@gtmship/auth-service",
  "version": "0.1.16",
  "description": "GTMShip Auth Service — Self-hosted OAuth manager for GTM integrations",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src/prisma",
    "package.json"
  ],
  "scripts": {
    "build": "prisma generate --schema src/prisma/schema.prisma && tsc",
    "dev": "prisma migrate deploy --schema src/prisma/schema.prisma && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate --schema src/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "db:push": "prisma db push --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@activepieces/piece-airtable": "^0.6.6",
    "@activepieces/piece-apollo": "^0.1.4",
    "@activepieces/piece-discord": "^0.4.4",
    "@activepieces/piece-github": "^0.6.7",
    "@activepieces/piece-gmail": "^0.11.6",
    "@activepieces/piece-google-calendar": "^0.9.1",
    "@activepieces/piece-google-docs": "^0.4.1",
    "@activepieces/piece-google-drive": "^0.7.1",
    "@activepieces/piece-google-sheets": "^0.14.6",
    "@activepieces/piece-hubspot": "^0.8.4",
    "@activepieces/piece-hunter": "^0.1.3",
    "@activepieces/piece-instantly-ai": "^0.1.4",
    "@activepieces/piece-intercom": "^0.7.0",
    "@activepieces/piece-jira-cloud": "^0.2.6",
    "@activepieces/piece-linear": "^0.3.0",
    "@activepieces/piece-linkedin": "^0.2.4",
    "@activepieces/piece-mailchimp": "^0.5.3",
    "@activepieces/piece-microsoft-teams": "^0.3.13",
    "@activepieces/piece-neverbounce": "^0.1.4",
    "@activepieces/piece-notion": "^0.6.1",
    "@activepieces/piece-salesforce": "^0.7.1",
    "@activepieces/piece-sendgrid": "^0.5.1",
    "@activepieces/piece-shopify": "^0.2.4",
    "@activepieces/piece-slack": "^0.14.2",
    "@activepieces/piece-smartlead": "^0.0.1",
    "@activepieces/piece-stripe": "^0.6.5",
    "@activepieces/piece-twilio": "^0.4.5",
    "@activepieces/piece-zendesk": "^0.2.6",
    "@activepieces/piece-zoom": "^0.6.1",
    "@activepieces/pieces-framework": "^0.26.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.840.0",
    "@aws-sdk/client-sts": "^3.0.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "google-auth-library": "^10.0.0",
